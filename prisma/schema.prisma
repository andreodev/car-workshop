generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ClientPersonType {
  FISICA
  JURIDICA
}

enum ClientStatus {
  ATIVO
  INATIVO
}

enum ClientIcms {
  ISENTO
  CONTRIBUINTE
  NAO_CONTRIBUINTE
}

enum VehicleStatus {
  ATIVO
  INATIVO
}

enum VehicleFuel {
  GASOLINA
  ETANOL
  DIESEL
  FLEX
  GNV
  ELETRICO
  HIBRIDO
}

enum ServiceOrderStatus {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECAS
  IMPEDIDA
  FINALIZADA
  CANCELADA
}

enum EstimateStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  REJEITADO
  CONVERTIDO
  CANCELADO
}

enum CatalogItemType {
  PRODUTO
  SERVICO
}

enum SaleStatus {
  CONCLUIDA
  CANCELADA
}

enum SalePaymentMethod {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  BOLETO
  OUTRO
}

enum FinancialAccountType {
  RECEBER
  PAGAR
}

enum FinancialAccountStatus {
  ABERTA
  PAGA
  VENCIDA
  CANCELADA
}

enum SupplierPersonType {
  FISICA
  JURIDICA
}

enum SupplierOrderStatus {
  ABERTO
  RECEBIDO
  CANCELADO
}

model Client {
  id              String          @id @default(cuid())
  personType      ClientPersonType @default(FISICA)
  status          ClientStatus     @default(ATIVO)
  icms            ClientIcms       @default(ISENTO)
  name            String
  cpf             String?
  rg              String?
  birthDate       DateTime?
  notesBasic      String?          @db.Text

  email           String?
  phoneResidential String?
  phoneCommercial String?
  mobile          String?
  phone1          String?
  phone2          String?
  phone3          String?
  phone4          String?
  website         String?
  social          String?
  otherContact    String?
  notesContacts   String?          @db.Text

  cep             String?
  address         String?
  number          String?
  complement      String?
  state           String?
  city            String?
  neighborhood    String?
  ibgeCode        String?
  notesAddress    String?          @db.Text

  vehicles        Vehicle[]
  serviceOrders   ServiceOrder[]
  estimates       Estimate[]
  sales           Sale[]
  financialAccounts FinancialAccount[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([name])
  @@index([cpf])
  @@index([email])
}

model Vehicle {
  id              String        @id @default(cuid())
  code            Int           @unique @default(autoincrement())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  plate           String
  brand           String?
  model           String?
  version         String?
  fleet           String?
  fuel            VehicleFuel?
  color           String?
  chassis         String?
  renavam         String?
  engine          String?
  city            String?
  status          VehicleStatus @default(ATIVO)
  manufactureYear Int?
  modelYear       Int?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  serviceOrders   ServiceOrder[]
  estimates       Estimate[]

  @@index([plate])
  @@index([brand])
  @@index([model])
  @@index([clientId])
  @@index([status])
  @@index([code])
}

model ServiceOrder {
  id             String             @id @default(cuid())
  code           Int                @unique @default(autoincrement())
  status         ServiceOrderStatus @default(ABERTA)
  clientId       String
  client         Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicleId      String
  vehicle        Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  mechanicId     String?
  mechanic       Mechanic?          @relation(fields: [mechanicId], references: [id], onDelete: SetNull)
  responsible    String
  location       String?
  km             Int?
  entryAt        DateTime
  estimatedAt    DateTime?
  notesInternal  String?            @db.Text
  notesClient    String?            @db.Text
  subtotal       Decimal            @db.Decimal(10, 2)
  discountTotal  Decimal            @default(0) @db.Decimal(10, 2)
  total          Decimal            @db.Decimal(10, 2)
  items          ServiceOrderItem[]
  estimateConversion Estimate?       @relation("EstimateConversion")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([code])
  @@index([clientId])
  @@index([vehicleId])
  @@index([mechanicId])
  @@index([status])
  @@index([entryAt])
}

model ServiceOrderItem {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  description    String
  quantity       Int
  unitPrice      Decimal      @db.Decimal(10, 2)
  discount       Decimal      @default(0) @db.Decimal(10, 2)
  total          Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([serviceOrderId])
}

model Estimate {
  id                      String         @id @default(cuid())
  code                    Int            @unique @default(autoincrement())
  status                  EstimateStatus @default(RASCUNHO)
  type                    String         @default("SIMPLES")
  clientId                String
  client                  Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  vehicleId               String
  vehicle                 Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  responsible             String
  validUntil              DateTime?
  notesInternal           String?        @db.Text
  notesClient             String?        @db.Text
  subtotal                Decimal        @db.Decimal(10, 2)
  discountTotal           Decimal        @default(0) @db.Decimal(10, 2)
  total                   Decimal        @db.Decimal(10, 2)
  convertedServiceOrderId String?        @unique
  convertedServiceOrder   ServiceOrder?  @relation("EstimateConversion", fields: [convertedServiceOrderId], references: [id], onDelete: SetNull)
  items                   EstimateItem[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([code])
  @@index([clientId])
  @@index([vehicleId])
  @@index([status])
  @@index([validUntil])
}

model EstimateItem {
  id          String   @id @default(cuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([estimateId])
}

model CatalogItem {
  id                         String          @id @default(cuid())
  code                       Int             @unique @default(autoincrement())
  type                       CatalogItemType @default(PRODUTO)
  name                       String
  sku                        String?
  barcode                    String?
  category                   String?
  unit                       String?
  manufacturerBrand          String?
  location                   String?
  originalCode               String?
  manufacturerCode           String?
  sectorId                   String?
  sector                     Sector?         @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  expirationDate             DateTime?
  stockCurrent               Decimal?        @db.Decimal(10, 3)
  stockMinimum               Decimal?        @db.Decimal(10, 3)
  stockMaximum               Decimal?        @db.Decimal(10, 3)
  tablePrice                 Decimal?        @db.Decimal(10, 2)
  supplierDiscountPercent    Decimal?        @db.Decimal(5, 2)
  purchasePrice              Decimal?        @db.Decimal(10, 2)
  profitPercent              Decimal?        @db.Decimal(5, 2)
  salePrice                  Decimal?        @db.Decimal(10, 2)
  unitPrice                  Decimal         @db.Decimal(10, 2)
  applicationDescription     String?         @db.Text
  substituteCodes            Json?
  supplierQuotes             Json?
  taxCeanTrib                String?
  taxNcm                     String?
  taxCest                    String?
  taxCfop                    String?
  taxCommercialUnit          String?
  taxCommercialQuantity      Decimal?        @db.Decimal(10, 4)
  taxCommercialUnitValue     Decimal?        @db.Decimal(10, 2)
  taxTribUnit                String?
  taxTribQuantity            Decimal?        @db.Decimal(10, 4)
  taxTribUnitValue           Decimal?        @db.Decimal(10, 2)
  taxInsuranceTotal          Decimal?        @db.Decimal(10, 2)
  taxDiscount                Decimal?        @db.Decimal(10, 2)
  taxFreightTotal            Decimal?        @db.Decimal(10, 2)
  taxOtherExpenses           Decimal?        @db.Decimal(10, 2)
  taxGrossTotal              Decimal?        @db.Decimal(10, 2)
  taxExTipi                  String?
  taxScaleIndicator          String?
  taxManufacturerCnpj        String?
  taxBenefitCode             String?
  taxPurchaseOrder           String?
  taxPurchaseOrderItem       String?
  taxFciControlNumber        String?
  taxFederalApproxPercent    Decimal?        @db.Decimal(5, 2)
  taxStateApproxPercent      Decimal?        @db.Decimal(5, 2)
  ipiTaxSituation            String?
  ipiClass                   String?
  ipiLegalCode               String?
  ipiProducerCnpj            String?
  ipiSealCode                String?
  ipiSealQuantity            Decimal?        @db.Decimal(10, 3)
  ipiCalculationType         String?
  ipiBase                    Decimal?        @db.Decimal(10, 2)
  ipiRate                    Decimal?        @db.Decimal(5, 2)
  ipiUnitValue               Decimal?        @db.Decimal(10, 2)
  ipiValue                   Decimal?        @db.Decimal(10, 2)
  icmsTaxSituation           String?
  icmsCalculationType        String?
  icmsBase                   Decimal?        @db.Decimal(10, 2)
  icmsRate                   Decimal?        @db.Decimal(5, 2)
  icmsValue                  Decimal?        @db.Decimal(10, 2)
  icmsNotes                  String?         @db.Text
  pisTaxSituation            String?
  pisCalculationType         String?
  pisBase                    Decimal?        @db.Decimal(10, 2)
  pisRate                    Decimal?        @db.Decimal(5, 2)
  pisValue                   Decimal?        @db.Decimal(10, 2)
  pisNotes                   String?         @db.Text
  cofinsTaxSituation         String?
  cofinsCalculationType      String?
  cofinsBase                 Decimal?        @db.Decimal(10, 2)
  cofinsRate                 Decimal?        @db.Decimal(5, 2)
  cofinsValue                Decimal?        @db.Decimal(10, 2)
  cofinsNotes                String?         @db.Text
  importBase                 Decimal?        @db.Decimal(10, 2)
  importExpenses             Decimal?        @db.Decimal(10, 2)
  importIof                  Decimal?        @db.Decimal(10, 2)
  importValue                Decimal?        @db.Decimal(10, 2)
  importNotes                String?         @db.Text
  fuelAnpCode                String?
  fuelDescription            String?
  fuelGlpPercent             Decimal?        @db.Decimal(5, 2)
  fuelNationalGasPercent     Decimal?        @db.Decimal(5, 2)
  fuelImportedGasPercent     Decimal?        @db.Decimal(5, 2)
  fuelCideBase               Decimal?        @db.Decimal(10, 2)
  fuelCideRate               Decimal?        @db.Decimal(10, 4)
  fuelCideValue              Decimal?        @db.Decimal(10, 2)
  fuelNotes                  String?         @db.Text
  ibsCbsCst                  String?
  ibsCbsClassification       String?
  ibsUfRate                  Decimal?        @db.Decimal(5, 2)
  ibsMunicipalRate           Decimal?        @db.Decimal(5, 2)
  cbsRate                    Decimal?        @db.Decimal(5, 2)
  ibsValue                   Decimal?        @db.Decimal(10, 2)
  cbsValue                   Decimal?        @db.Decimal(10, 2)
  ibsCbsNotes                String?         @db.Text
  active                     Boolean         @default(true)
  notes                      String?         @db.Text
  saleItems                  SaleItem[]
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt

  @@index([code])
  @@index([name])
  @@index([sku])
  @@index([barcode])
  @@index([category])
  @@index([sectorId])
  @@index([active])
  @@index([type])
}

model Sector {
  id        String   @id @default(cuid())
  code      Int      @unique @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  notes     String?  @db.Text
  sales     Sale[]
  products  CatalogItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@index([active])
}

model Mechanic {
  id        String   @id @default(cuid())
  code      Int      @unique @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  notes     String?  @db.Text
  serviceOrders ServiceOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@index([active])
}

model Supplier {
  id              String             @id @default(cuid())
  code            Int                @unique @default(autoincrement())
  personType      SupplierPersonType @default(FISICA)
  name            String
  cpf             String?
  rg              String?
  contact         String?
  productLine     String?
  phone1          String?
  phone2          String?
  phone3          String?
  phone4          String?
  email           String?
  website         String?
  cep             String?
  city            String?
  state           String?
  address         String?
  neighborhood    String?
  bank            String?
  account         String?
  agency          String?
  notes           String?            @db.Text
  orders          SupplierOrder[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([code])
  @@index([name])
  @@index([cpf])
  @@index([email])
  @@index([productLine])
}

model SupplierOrder {
  id                  String              @id @default(cuid())
  code                Int                 @unique @default(autoincrement())
  status              SupplierOrderStatus @default(ABERTO)
  supplierId          String
  supplier            Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  employee            String
  forecastAt          DateTime
  invoiceNumber       String?
  observation         String?             @db.Text
  internalDescription String?             @db.Text
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([code])
  @@index([supplierId])
  @@index([employee])
  @@index([forecastAt])
  @@index([status])
}

model Sale {
  id            String            @id @default(cuid())
  code          Int               @unique @default(autoincrement())
  status        SaleStatus        @default(CONCLUIDA)
  clientId      String?
  client        Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sectorId      String?
  sector        Sector?           @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  responsible   String
  sectorName    String?           @map("sector")
  paymentMethod SalePaymentMethod @default(DINHEIRO)
  notes         String?           @db.Text
  subtotal      Decimal           @db.Decimal(10, 2)
  discountTotal Decimal           @default(0) @db.Decimal(10, 2)
  total         Decimal           @db.Decimal(10, 2)
  items         SaleItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([code])
  @@index([clientId])
  @@index([sectorId])
  @@index([status])
  @@index([createdAt])
  @@index([responsible])
}

model SaleItem {
  id            String       @id @default(cuid())
  saleId        String
  sale          Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  catalogItemId String?
  catalogItem   CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  description   String
  quantity      Decimal      @db.Decimal(10, 3)
  unitPrice     Decimal      @db.Decimal(10, 2)
  discount      Decimal      @default(0) @db.Decimal(10, 2)
  total         Decimal      @db.Decimal(10, 2)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([saleId])
  @@index([catalogItemId])
}

model FinancialAccount {
  id          String                 @id @default(cuid())
  code        Int                    @unique @default(autoincrement())
  type        FinancialAccountType
  status      FinancialAccountStatus @default(ABERTA)
  description String
  clientId    String?
  client      Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  counterparty String?
  category    String?
  documentNumber String?
  dueDate     DateTime
  paymentDate DateTime?
  amount      Decimal                @db.Decimal(10, 2)
  paidAmount  Decimal?               @db.Decimal(10, 2)
  paymentMethod SalePaymentMethod?
  notes       String?                @db.Text
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([code])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
  @@index([description])
}
